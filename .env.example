# Network portal sync. Optional until the shared portal API is connected.
NEXT_PUBLIC_NETWORK_API_URL=
NETWORK_SYNC_SECRET=

# Server-side database connection. Keep this secret and never prefix it with NEXT_PUBLIC_.
MONGODB_URL=
NETWORK_MONGODB_DB=network

# Portal SSO. Must be exactly the same value as PORTAL_SSO_SECRET in portal-network.
PORTAL_SSO_SECRET=
NEXT_PUBLIC_PORTAL_AUTH_URL=https://portal-network.vercel.app/api/auth/portal-sso/start
NEXT_PUBLIC_KINGSTARS_URL=https://land-of-smiles.vercel.app

# Clerk authentication. Optional until login/profile pages are connected.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/register
NEXT_PUBLIC_CLERK_SIGN_UP_FORCE_REDIRECT_URL=/

# Clerk webhook secret. Optional until we add a webhook route.
WEBHOOK_SECRET=

# Portal Anima. These server-side values let /api/anima/chat use the same
# NVIDIA-compatible model as the Telegram Anima bot without touching Telegram webhook.
ANIMA_NVIDIA_API_KEY=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
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-super-120b-a12b
NVIDIA_TEMPERATURE=1
NVIDIA_TOP_P=0.95
NVIDIA_MAX_TOKENS=16384
NVIDIA_TIMEOUT_SECONDS=45
NVIDIA_ENABLE_THINKING=true
NVIDIA_REASONING_BUDGET=16384

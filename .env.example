TELEGRAM_CLIENT_SECRET=
KINGSTARS_SESSION_SECRET=

# Clerk webhook secret. Optional until we add a webhook route.
WEBHOOK_SECRET=

# Portal Anima. These server-side values let /api/anima/chat use the same
